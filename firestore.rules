rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasGroupId() {
      return request.resource.data.groupId is string;
    }

    match /trekPrepGroups/{groupId} {
      allow read: if true;
      allow create, update: if request.resource.data.id == groupId
        && !request.resource.data.keys().hasAny(["adminToken"]);
    }

    match /trekPrepAdmins/{adminToken} {
      allow get: if true;
      allow list: if false;
      allow create, update: if request.resource.data.groupId is string;
      allow delete: if true;
    }

    match /trekPrepParticipants/{participantId} {
      allow read: if true;
      allow create, update: if request.resource.data.id == participantId && hasGroupId();
    }

    match /trekPrepLogs/{logId} {
      allow read: if true;
      allow create: if request.resource.data.id == logId && hasGroupId();
    }

    match /trekPrepTotals/{totalId} {
      allow read: if true;
      allow create, update: if request.resource.data.id == totalId && hasGroupId();
      allow delete: if true;
    }
  }
}
